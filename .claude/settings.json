{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/block-pip.sh\"",
            "timeout": 5,
            "statusMessage": "检查 pip 使用（强制 uv）..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/ruff-check.sh\"",
            "timeout": 60,
            "statusMessage": "运行 ruff 检查..."
          }
        ]
      }
    ]
  }
}

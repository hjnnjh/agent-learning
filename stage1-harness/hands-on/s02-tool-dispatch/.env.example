# DeepSeek API（OpenAI 兼容端点）
# 在控制台创建 key：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key

# OpenAI 兼容基址（默认即可；beta 特性用 https://api.deepseek.com/beta）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# deepseek-chat 支持函数调用（本课用它）；deepseek-reasoner 不支持工具调用，勿用于本课
MODEL_ID=deepseek-chat
